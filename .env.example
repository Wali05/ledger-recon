# Copy this to .env and fill in values (or use docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://recon_user:recon_pass@localhost:5432/ledger_recon
SYNC_DATABASE_URL=postgresql://recon_user:recon_pass@localhost:5432/ledger_recon
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Comma-separated list of browser origins allowed to call the API directly (CORS).
# Production traffic goes through the Vercel /api proxy (same-origin, no CORS needed),
# so this mainly matters for local dev or direct calls to the backend host.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gemini API key for the AI break-explanation feature.
GEMINI_API_KEY=your-key-here

# Postgres password (used by docker-compose).
POSTGRES_PASSWORD=change-me
